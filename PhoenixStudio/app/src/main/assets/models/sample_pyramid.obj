# Phoenix Studio bootstrap test asset — a simple square pyramid.
# Deliberately has no "vn" (normal) lines, so parsing this exercises
# ObjParser's flat-per-face-normal fallback path, not just the common case
# where a real export (e.g. a Kenney/Quaternius pack) already includes normals.

v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5 -0.5  0.5
v -0.5 -0.5  0.5
v  0.0  0.5  0.0

f 1 2 3
f 1 3 4
f 1 2 5
f 2 3 5
f 3 4 5
f 4 1 5
